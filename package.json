{
  "name": "decay-cards",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/dist-split.mjs",
    "preview": "vite preview",
    "typecheck": "tsgo -b",
    "lint": "oxlint --type-aware src",
    "lint:fix": "oxlint --type-aware --fix src",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "lint:knip": "knip",
    "check": "pnpm lint && pnpm lint:knip && pnpm format:check && pnpm test:run",
    "test": "vitest",
    "test:run": "vitest run --exclude '**/*.prop.test.ts'",
    "test:pbt": "FAST_CHECK_NUM_RUNS=1000 vitest run '.prop.test.ts'",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@atproto/api": "^0.20.9",
    "@atproto/oauth-client-browser": "^0.4.1",
    "@dweb-browser/zstd-wasm": "^1.2.1",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@tiptap/vue-3": "^3.26.0",
    "@zip-js/zip-js": "npm:@jsr/zip-js__zip-js@^2.7.57",
    "katex": "^0.16.21",
    "mime": "^4.1.0",
    "protobufjs": "^7.5.5",
    "sql.js": "^1.12.0",
    "tailwindcss": "^4.2.2",
    "ts-fsrs": "^5.2.3",
    "vue": "^3.5.13",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.9.2",
    "@types/sql.js": "^1.4.9",
    "@typescript/native-preview": "latest",
    "@vitejs/plugin-vue": "^6.0.4",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.7.0",
    "happy-dom": "^20.0.11",
    "knip": "^6.16.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3",
    "vite": "npm:rolldown-vite@^7.3.0",
    "vitest": "^4.0.16"
  }
}
